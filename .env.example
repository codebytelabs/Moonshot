# ===== Exchanges =====
BINANCE_API_KEY=
BINANCE_API_SECRET=

GATEIO_API_KEY=
GATEIO_API_SECRET=
GATEIO_UID=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# ===== LLM APIs =====
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_API_KEY=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
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=deepseek/deepseek-r1-0528:free # Retaining user's specific model choice
OPENROUTER_SECONDARY_MODEL=deepseek/deepseek-v3.2-exp
OPENROUTER_SECONDARY2_MODEL=z-ai/glm-5
OPENROUTER_PERPLEXITY_MODEL=perplexity/sonar-pro-search


PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar

# ===== Database =====
# Option 1: Supabase (Recommended)
SUPABASE_URL=
SUPABASE_KEY=

# Option 2: Local PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=trader
POSTGRES_PASSWORD=

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Bot Configuration =====
MODE=paper  # paper, sim, live
CYCLE_INTERVAL_SECONDS=300  # 5 minutes
LOG_LEVEL=INFO

# ===== Position Management =====
MAX_CONCURRENT_POSITIONS=8
BASE_RISK_PER_TRADE_PCT=0.015  # 1.5%
MAX_RISK_PER_TRADE_PCT=0.03    # 3.0% (high conviction)
MAX_SINGLE_EXPOSURE_PCT=0.20   # 20% max per position
MAX_TOTAL_EXPOSURE_PCT=0.80    # 80% max total exposure

# Pyramiding
PYRAMID_ENABLED=true
PYRAMID_MAX_ADDS=2

# Tiered Exits
TIER1_EXIT_PCT=0.25  # 25% at 2R
TIER1_R_LEVEL=2.0

TIER2_EXIT_PCT=0.25  # 25% at 5R
TIER2_R_LEVEL=5.0

RUNNER_PCT=0.50  # 50% as runner

# Trailing Stops
TRAIL_STOP_INITIAL=0.10   # 10% initial
TRAIL_STOP_TIER2=0.15     # 15% after tier2
TRAIL_STOP_RUNNER=0.25    # 25% for runners

# ===== Risk Limits =====
MAX_DRAWDOWN_PCT=0.20       # 20% max drawdown
DAILY_LOSS_LIMIT_PCT=0.05   # 5% daily loss limit
MAX_CORRELATION_EXPOSURE=0.50  # 50% max in correlated assets

# ===== Watcher Agent =====
WATCHER_MIN_VOLUME_24H=2000000  # $2M minimum 24h volume
WATCHER_MAX_SPREAD_PCT=0.5      # 0.5% max spread
WATCHER_TOP_N=15                # Top 15 candidates

# ===== Analyzer Agent =====
ANALYZER_MIN_TA_SCORE=70.0      # Minimum TA score
ANALYZER_SHORTLIST_N=8          # Top 8 setups

# ===== Bayesian Engine =====
BAYESIAN_THRESHOLD_NORMAL=0.70    # 70% confidence for normal mode
BAYESIAN_THRESHOLD_AGGRESSIVE=0.65
BAYESIAN_THRESHOLD_SAFETY=0.80

# ===== Alerts & Notifications =====
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

# ===== Monitoring =====
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ===== Development =====
DEBUG=false
ENABLE_BACKTESTING=false
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2025-01-01
